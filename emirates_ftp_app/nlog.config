<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Trace"
      internalLogFile="${basedir}/logs/internal-nlog.log">

	<targets>
		<target xsi:type="Console"
				name="console"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=ToString}" />

		<!--<target xsi:type="File"
				name="file"
				fileName="${basedir}/logs/${gdc:item=ModuleName}_${gdc:item=RunStamp}.log"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=ToString}"
				createDirs="true"
				keepFileOpen="false"
				encoding="utf-8" />-->

		<target xsi:type="File"
					name="file"
					fileName="${basedir}/logs/${gdc:item=ModuleName}/${date:format=yyyy}/${date:format=MMM}/${date:format=dd}/${gdc:item=ModuleName}_${gdc:item=RunStamp}.log"
					layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=ToString}"
					createDirs="true"
					keepFileOpen="false"
					encoding="utf-8" />
	</targets>

	<rules>
		<!-- ✅ Block EF Core SQL / DbCommand logs -->
		<logger name="Microsoft.EntityFrameworkCore.Model.Validation*" minlevel="Trace" final="true" />
		<logger name="Microsoft.EntityFrameworkCore.Database.Command*" minlevel="Trace" final="true" />
		<!--<logger name="Microsoft.EntityFrameworkCore.Database.Command" minlevel="Trace" final="true" />-->
		<logger name="Microsoft.EntityFrameworkCore.Infrastructure" minlevel="Trace" final="true" />
		<logger name="*" minlevel="Info" writeTo="console,file" />
	</rules>

</nlog>